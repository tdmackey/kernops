From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juerg Haefliger <juerg.haefliger@canonical.com>
Date: Tue, 24 Jun 2025 11:54:47 +0200
Subject: [PATCH] UBUNTU: [Packaging] Install compressed vmlinuz.efi on arm64

BugLink: https://bugs.launchpad.net/bugs/2098111

Signed-off-by: Juerg Haefliger <juerg.haefliger@canonical.com>
Signed-off-by: Paolo Pisati <paolo.pisati@canonical.com>
(cherry picked from commit afb3295e433815850a8a22ccd24b8f4a7c3bc229)
---
 debian.master/rules.d/arm64.mk | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/debian.master/rules.d/arm64.mk b/debian.master/rules.d/arm64.mk
index 2f23ecddcea0..109ee6e1b849 100644
--- a/debian.master/rules.d/arm64.mk
+++ b/debian.master/rules.d/arm64.mk
@@ -2,8 +2,8 @@ human_arch	= ARMv8
 build_arch	= arm64
 defconfig	= defconfig
 flavours	= generic generic-64k
-build_image	= Image.gz
-kernel_file	= arch/$(build_arch)/boot/Image.gz
+build_image	= vmlinuz.efi
+kernel_file	= arch/$(build_arch)/boot/vmlinuz.efi
 install_file	= vmlinuz
 no_dumpfile = true
 uefi_signed     = true
-- 
